{
  "manifest_version": 3,
  "name": "🧠 OmniContext",
  "version": "1.0.0",
  "description": "跨平台AI对话上下文管理工具 - 在不同AI助手间共享记忆",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+M",
        "mac": "Command+M"
      },
      "description": "打开/关闭 OmniContext 侧边栏"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "nativeMessaging",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.doubao.com/*",
    "https://yuanbao.tencent.com/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*",
    "https://www.kimi.com/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "OmniContext - 打开侧边栏",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg",
      "256": "icons/icon.svg"
    }
  },
  "side_panel": {
    "default_path": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg",
      "256": "icons/icon.svg"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.doubao.com/*",
        "https://yuanbao.tencent.com/*",
        "https://claude.ai/*",
        "https://chat.deepseek.com/*",
        "https://www.kimi.com/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/platforms/*.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
