{
  "manifest_version": 3,
  "name": "ContextDrop",
  "version": "1.0.0",
  "description": "用于捕获和注入AI对话记录的浏览器插件，帮助用户在不同AI助手之间流转上下文记忆",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+M",
        "mac": "Command+M"
      },
      "description": "打开/关闭 ContextDrop 侧边栏"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "nativeMessaging",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.doubao.com/*",
    "https://yuanbao.tencent.com/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*",
    "https://www.kimi.com/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "ContextDrop - 打开侧边栏",
    "default_icon": {
      "16": "icons/context-drop-16.png",
      "32": "icons/context-drop-32.png",
      "48": "icons/context-drop-48.png",
      "128": "icons/context-drop-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/popup/index.html",
    "default_icon": {
      "16": "icons/context-drop-16.png",
      "32": "icons/context-drop-32.png",
      "48": "icons/context-drop-48.png",
      "128": "icons/context-drop-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.doubao.com/*",
        "https://yuanbao.tencent.com/*",
        "https://claude.ai/*",
        "https://chat.deepseek.com/*",
        "https://www.kimi.com/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "icons": {
    "16": "icons/context-drop-16.png",
    "32": "icons/context-drop-32.png",
    "48": "icons/context-drop-48.png",
    "128": "icons/context-drop-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/platforms/*.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
